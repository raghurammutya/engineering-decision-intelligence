{
  "schema_version": 1,
  "milestone": "DIP governed decision review and simulation MVP",
  "source_boundary": "edi_governed_backlog_not_dip_runtime_implementation",
  "target_id": "dip-framework",
  "first_wedge": "Governed Decision Review and Simulation",
  "runtime_execution_allowed": false,
  "slices": [
    {
      "id": "decision-spec-contract-v1",
      "status": "planned",
      "purpose": "Define the versioned decision spec contract that captures reviewed intent before generated artifacts or runtime behavior.",
      "expected_outputs": ["decision spec schema", "example specs", "source-label requirements", "schema tests"],
      "acceptance": ["schema version required", "owner and environment scope required", "source labels required", "production defaults to not allowed"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "schema_contracts",
      "depends_on": [],
      "blocked_operations": ["production decision execution"]
    },
    {
      "id": "capability-registry-contract-v1",
      "status": "planned",
      "purpose": "Define governed capability metadata and version attribution for models, scripts, policies, transforms, connectors, and evaluation packs.",
      "expected_outputs": ["capability registry schema", "capability version examples", "checksum and owner fields", "contract tests"],
      "acceptance": ["capability id and version required", "owner required", "input and output contracts required", "evaluation evidence reference required"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "schema_contracts",
      "depends_on": [],
      "blocked_operations": ["marketplace runtime invocation"]
    },
    {
      "id": "policy-preflight-contract-v1",
      "status": "planned",
      "purpose": "Define deterministic policy preflight results before AI scoring, approval, simulation promotion, or runtime authority.",
      "expected_outputs": ["preflight result schema", "policy decision examples", "denied-result invariants", "contract tests"],
      "acceptance": ["allowed denied or approval_required result required", "violated policies recorded", "AI cannot override denied result"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "schema_contracts",
      "depends_on": [],
      "blocked_operations": ["AI approval", "policy bypass"]
    },
    {
      "id": "simulation-evidence-contract-v1",
      "status": "planned",
      "purpose": "Define fixture-based simulation evidence for decision changes before runtime integration.",
      "expected_outputs": ["simulation evidence schema", "fixture case-set contract", "changed outcome summary", "cost delta fields"],
      "acceptance": ["simulation run id required", "baseline version required", "case set required", "changed outcome count required"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "schema_contracts",
      "depends_on": ["decision-spec-contract-v1", "capability-registry-contract-v1"],
      "blocked_operations": ["live external side effects"]
    },
    {
      "id": "decision-diff-v1",
      "status": "planned",
      "purpose": "Generate behavioral and governance diffs between decision versions.",
      "expected_outputs": ["decision diff schema", "spec diff summary", "capability graph diff summary", "simulation outcome diff summary"],
      "acceptance": ["spec changes recorded", "capability version changes recorded", "policy impact recorded", "simulation changes recorded"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "pre_runtime_engines",
      "depends_on": ["decision-spec-contract-v1", "capability-registry-contract-v1", "simulation-evidence-contract-v1"],
      "blocked_operations": ["runtime mutation"]
    },
    {
      "id": "approval-record-contract-v1",
      "status": "planned",
      "purpose": "Define approval request and approval decision evidence for governed decision changes.",
      "expected_outputs": ["approval request schema", "approval decision schema", "reviewer identity fields", "approval reason fields"],
      "acceptance": ["approver identity required", "decision required", "approval reason required", "policy preflight reference required"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "pre_runtime_engines",
      "depends_on": ["policy-preflight-contract-v1", "simulation-evidence-contract-v1"],
      "blocked_operations": ["AI self-approval"]
    },
    {
      "id": "case-evidence-pack-v1",
      "status": "planned",
      "purpose": "Define append-only case evidence that preserves decision request, spec version, capability versions, preflight, simulation, diff, and approval.",
      "expected_outputs": ["case evidence schema", "case evidence writer", "lineage references", "case evidence tests"],
      "acceptance": ["case id required", "decision spec version required", "capability graph snapshot required", "approval or rejection evidence required"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "pre_runtime_engines",
      "depends_on": ["decision-diff-v1", "approval-record-contract-v1"],
      "blocked_operations": ["mutable case rewrite"]
    },
    {
      "id": "replay-reader-v1",
      "status": "planned",
      "purpose": "Read stored case evidence and compare replayed results without invoking production runtime.",
      "expected_outputs": ["replay input contract", "replay result schema", "replay comparison summary", "replay tests"],
      "acceptance": ["original case reference required", "capability versions required", "policy versions required", "replay outcome diff required"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "pre_runtime_engines",
      "depends_on": ["case-evidence-pack-v1"],
      "blocked_operations": ["production replay side effects"]
    },
    {
      "id": "mvp-trust-loop-cli-v1",
      "status": "planned",
      "purpose": "Assemble the pre-runtime trust loop as a CLI-first executable path.",
      "expected_outputs": ["DIP CLI command", "fixture decision spec", "fixture capability registry", "generated case evidence"],
      "acceptance": ["spec validates", "preflight runs", "simulation runs", "diff generated", "approval record generated", "case evidence written", "replay reads case"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "serialized_integration",
      "depends_on": ["replay-reader-v1"],
      "blocked_operations": ["production runtime integration"]
    },
    {
      "id": "dip-mvp-acceptance-pack-v1",
      "status": "planned",
      "purpose": "Generate a DIP MVP acceptance pack that prevents trust-loop and runtime-readiness overclaims.",
      "expected_outputs": ["DIP MVP acceptance report", "machine-readable acceptance export", "acceptance gates", "product API metrics"],
      "acceptance": ["trust loop evidence complete before MVP claim", "runtime integration blocked", "production decision execution blocked"],
      "allowed_autonomy": "controlled_execute",
      "parallelization_group": "serialized_integration",
      "depends_on": ["mvp-trust-loop-cli-v1"],
      "blocked_operations": ["runtime readiness overclaim"]
    }
  ]
}
