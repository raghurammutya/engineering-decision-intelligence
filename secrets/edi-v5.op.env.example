# Copy this file to secrets/edi-v5.op.env and replace EDI_OP_VAULT with your
# dedicated 1Password vault name or ID. Do not put plaintext secrets here.
#
# Run commands with:
#   EDI_OP_VAULT=<vault> op run --env-file=secrets/edi-v5.op.env -- python3 -m edi v5 build --live-check

EDI_GITHUB_TOKEN="op://$EDI_OP_VAULT/EDI GitHub/token"
EDI_DEPLOYMENT_TOKEN="op://$EDI_OP_VAULT/EDI Deployment/token"
EDI_OBSERVABILITY_TOKEN="op://$EDI_OP_VAULT/EDI Observability/token"
EDI_INCIDENT_TOKEN="op://$EDI_OP_VAULT/EDI Incident/token"
EDI_OWNERSHIP_TOKEN="op://$EDI_OP_VAULT/EDI Ownership/token"
