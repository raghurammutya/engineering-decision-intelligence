{
  "schema_version": 1,
  "target_id": "dip-framework",
  "target_name": "Decision Intelligence Platform",
  "relationship_to_edi": "edi_builds_and_governs_dip_but_does_not_run_dip_runtime",
  "first_wedge": "Governed Decision Review and Simulation",
  "source_boundary": "declared_policy_not_dip_runtime_evidence",
  "fail_closed": true,
  "runtime_authority": {
    "edi_runtime_authority": "none",
    "dip_runtime_authority": "deferred",
    "blocked_until_evidenced": [
      "production_decision_execution",
      "marketplace_runtime_invocation",
      "shared_context_runtime_exchange",
      "billing_or_metering_runtime",
      "autonomous_ai_execution"
    ]
  },
  "governance_principles": [
    "decision_spec_is_source_of_intent",
    "generated_artifacts_are_derived_outputs",
    "deterministic_policy_before_ai_scoring",
    "ai_may_propose_but_not_approve_or_bypass_policy",
    "source_labels_are_visible_and_reviewable",
    "approval_and_case_evidence_precede_runtime_authority",
    "readiness_claims_fail_closed_without_target_evidence"
  ],
  "source_labels": [
    "user_declared",
    "imported",
    "observed",
    "inferred",
    "ai_proposed",
    "user_reviewed",
    "policy_derived",
    "system_generated"
  ],
  "wedge_loop": [
    "draft_decision_spec",
    "attach_capability_versions",
    "generate_capability_graph",
    "run_policy_preflight",
    "run_simulation",
    "generate_decision_diff",
    "request_approval",
    "record_approval_decision",
    "store_immutable_case_evidence",
    "replay_or_compare_later"
  ],
  "readiness_domains": [
    {
      "id": "decision_spec",
      "label": "Versioned decision spec contract",
      "required_evidence": [
        "schema_version",
        "decision_id",
        "decision_version",
        "owner",
        "environment_scope",
        "intent",
        "inputs",
        "outputs",
        "side_effects",
        "risk",
        "approval",
        "simulation",
        "evidence_requirements",
        "source_labels"
      ]
    },
    {
      "id": "capability_registry",
      "label": "Capability registry and graph contract",
      "required_evidence": [
        "capability_id",
        "capability_version",
        "owner",
        "trust_class",
        "risk_tier",
        "input_contract",
        "output_contract",
        "policy_dependencies",
        "evaluation_evidence_ref",
        "compatibility_result"
      ]
    },
    {
      "id": "policy_preflight",
      "label": "Deterministic policy preflight",
      "required_evidence": [
        "allowed_denied_or_approval_required",
        "violated_policies",
        "required_approvals",
        "missing_evidence",
        "environment_restrictions",
        "side_effect_restrictions",
        "remediation_guidance",
        "ai_cannot_override_denied_result"
      ]
    },
    {
      "id": "simulation",
      "label": "Simulation and decision diff evidence",
      "required_evidence": [
        "simulation_run_id",
        "decision_version",
        "baseline_decision_version",
        "case_set",
        "changed_outcome_count",
        "policy_decisions",
        "side_effects_requested",
        "cost_delta",
        "decision_diff"
      ]
    },
    {
      "id": "approval_case_store",
      "label": "Approval and immutable case evidence",
      "required_evidence": [
        "approval_request",
        "approval_decision",
        "approver_identity",
        "approval_reason",
        "case_id",
        "case_evidence_snapshot",
        "append_only_or_immutable_storage",
        "lineage_reference"
      ]
    },
    {
      "id": "replay",
      "label": "Replay and comparison evidence",
      "required_evidence": [
        "replay_reference",
        "original_case",
        "replayed_case",
        "capability_versions",
        "policy_versions",
        "replay_outcome_diff",
        "replay_evidence_link"
      ]
    },
    {
      "id": "marketplace_governance",
      "label": "Marketplace capability governance boundary",
      "required_evidence": [
        "artifact_type",
        "owner",
        "version",
        "checksum",
        "entitlement_status",
        "risk_tier",
        "approval_requirements",
        "deprecation_policy"
      ]
    },
    {
      "id": "shared_context_governance",
      "label": "Shared context governance boundary",
      "required_evidence": [
        "purpose",
        "producer",
        "consumer",
        "fields_shared_or_masked",
        "ttl",
        "freshness",
        "lineage",
        "policy_decision",
        "approval_or_consent_requirement"
      ]
    }
  ],
  "autopilot_lanes": [
    {
      "mode": "observe",
      "allowed": [
        "scan_dip_docs",
        "scan_dip_code",
        "read_evidence",
        "summarize_gaps"
      ]
    },
    {
      "mode": "recommend",
      "allowed": [
        "propose_backlog",
        "propose_acceptance_gates",
        "propose_owner_and_risk_assignments",
        "propose_scope_reductions"
      ]
    },
    {
      "mode": "prepare",
      "allowed": [
        "draft_schemas",
        "draft_tests",
        "draft_docs",
        "draft_non_runtime_cli"
      ]
    },
    {
      "mode": "controlled_execute",
      "allowed": [
        "implement_pre_runtime_cli",
        "implement_schema_validation",
        "implement_report_generation",
        "implement_fixture_simulation"
      ]
    },
    {
      "mode": "blocked",
      "allowed": [],
      "blocked": [
        "production_decision_execution",
        "external_runtime_connectors",
        "marketplace_runtime_invocation",
        "shared_context_runtime_exchange",
        "secrets_mutation",
        "direct_production_mutation"
      ]
    }
  ]
}
